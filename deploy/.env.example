# ============================================================
# SWARM_CTRL — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ============================================================

# ─── Veritabanı ────────────────────────────────────────────
# Docker Compose kullanıyorsanız bu değeri kullanın:
DATABASE_URL=postgresql://swarm:swarm_secret_change_me@localhost:5432/swarm_ctrl

# Manuel PostgreSQL kurulumu için örnek:
# DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/swarm_ctrl

# Ayrı değişkenler (drizzle-kit için gerekebilir)
PGHOST=localhost
PGPORT=5432
PGUSER=swarm
PGPASSWORD=swarm_secret_change_me
PGDATABASE=swarm_ctrl

# ─── API Server ────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Üretimde NODE_ENV=production yapın

# ─── Frontend (Vite) ───────────────────────────────────────
# Frontend geliştirme sunucusu portu (API server ile çakışmamalı)
VITE_PORT=5173

# API'nin tam adresi (frontend'in istekleri gönderdiği yer)
VITE_API_URL=http://localhost:8080

# ─── Workspace (Ajan Dosyaları) ────────────────────────────
# Ajanların ürettiği dosyaların yazıldığı dizin
WORKSPACE_ROOT=/tmp/swarm_workspace

# ─── Ollama (Yerel LLM — opsiyonel) ───────────────────────
# Ollama kuruluysa gerçek LLM çağrısı için:
# OLLAMA_URL=http://localhost:11434/api/chat

# ─── OpenAI (opsiyonel) ────────────────────────────────────
# OPENAI_API_KEY=sk-...
